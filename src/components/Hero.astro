---

---

<section
 id="inicio"
 class="min-h-screen flex items-center justify-center relative overflow-hidden pt-20">
 <!-- Fondo Abstracto -->
 <div class="absolute inset-0 w-full h-full bg-slate-950">
  <div
   class="absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-purple-600/20 rounded-full blur-[120px] mix-blend-screen pointer-events-none">
  </div>
  <div
   class="absolute top-1/2 right-1/4 w-[400px] h-[400px] bg-blue-600/20 rounded-full blur-[120px] mix-blend-screen pointer-events-none">
  </div>
 </div>

 <div class="max-w-5xl mx-auto px-4 sm:px-6 relative z-10 text-center">
  <div
   class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-slate-900/50 border border-slate-800 shadow-xl mb-8">
   <svg
    xmlns="http://www.w3.org/2000/svg"
    width="28"
    height="28"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="text-purple-400"
    ><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"></path><path
     d="M19 10v2a7 7 0 0 1-14 0v-2"></path><line x1="12" x2="12" y1="19" y2="22"
    ></line></svg
   >
  </div>

  <h1
   class="text-5xl md:text-7xl lg:text-8xl font-extrabold tracking-tight text-white mb-6">
   Esther <span class="text-gradient">Morales</span>
  </h1>
  <p
   class="text-2xl md:text-3xl font-light text-slate-300 mb-8 max-w-3xl mx-auto">
   La voz que conecta con tu público.
  </p>
  <p class="text-lg text-slate-400 mb-12 max-w-2xl mx-auto hidden md:block">
   Locutora profesional, especialista en voiceover y doblaje con más de 10 años
   de experiencia dando vida a marcas e historias internacionales.
  </p>

  <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
   <a
    href="#demos"
    class="btn-primary w-full sm:w-auto text-center flex items-center justify-center gap-2">
    <svg
     xmlns="http://www.w3.org/2000/svg"
     width="20"
     height="20"
     viewBox="0 0 24 24"
     fill="none"
     stroke="currentColor"
     stroke-width="2"
     stroke-linecap="round"
     stroke-linejoin="round"
     ><polygon points="5 3 19 12 5 21 5 3"></polygon></svg
    >
    Escuchar demos
   </a>
   <a href="#contacto" class="btn-secondary w-full sm:w-auto text-center">
    Contratar
   </a>
  </div>
 </div>
</section>
